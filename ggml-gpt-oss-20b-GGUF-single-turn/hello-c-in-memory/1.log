fn main() -> Result<(), Box<dyn std::error::Error>> {
    // Determine unique temp file path
    let mut exe_path = std::env::temp_dir();
    let pid = std::process::id();
    let now = std::time::SystemTime::now()
        .duration_since(std::time::UNIX_EPOCH)?
        .as_millis();
    exe_path.push(format!("hello_{}_{}.exe", pid, now));
    // compile
    let mut gcc = std::process::Command::new("gcc")
        .arg("-x")
        .arg("c")
        .arg("-")
        .arg("-o")
        .arg(&exe_path)
        .stdin(std::process::Stdio::piped())
        .stderr(std::process::Stdio::inherit())
        .stdout(std::process::Stdio::inherit())
        .spawn()?;
    {
        let mut stdin = gcc.stdin.take().expect("Failed to open stdin");
        use std::io::Write;
        let c_code = r#"
        #include <stdio.h>
        int main(void) {
            puts("Hello, world!");
            return 0;
        }
        "#;
        stdin.write_all(c_code.as_bytes())?;
    }
    let status = gcc.wait()?;
    if !status.success() {
        eprintln!("Compilation failed");
        std::process::exit(1);
    }
    // run
    let status = std::process::Command::new(&exe_path)
        .status()?;
    if !status.success() {
        eprintln!("Execution failed");
        std::process::exit(1);
    }
    // delete
    std::fs::remove_file(&exe_path)?;
    Ok(())
}

